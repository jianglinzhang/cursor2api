# =========================
# Stage 1: Build
# =========================
FROM node:22-bookworm-slim AS builder

WORKDIR /app

# 先拷贝依赖定义，利用缓存
COPY package.json package-lock.json ./
RUN npm ci --ignore-scripts

# 拷贝源码并构建
COPY tsconfig.json ./
COPY src ./src
RUN npm run build


# =========================
# Stage 2: Runtime
# =========================
FROM node:22-bookworm-slim AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV NODE_OPTIONS="--max-old-space-size=4096"

# 给 stealth-proxy 显式指定 Chrome 路径
ENV CHROME_PATH=/usr/bin/google-chrome-stable

# Playwright 浏览器缓存目录（作为兜底）
ENV PLAYWRIGHT_BROWSERS_PATH=/app/.playwright-browsers

# 安装基础工具、Chrome 依赖、字体
RUN apt-get update && apt-get install -y --no-install-recommends \
    wget \
    curl \
    gnupg \
    ca-certificates \
    unzip \
    fonts-liberation \
    fonts-noto \
    fonts-noto-cjk \
    fonts-noto-color-emoji \
    libasound2 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libcups2 \
    libdbus-1-3 \
    libdrm2 \
    libgbm1 \
    libglib2.0-0 \
    libgtk-3-0 \
    libnspr4 \
    libnss3 \
    libu2f-udev \
    libvulkan1 \
    libx11-6 \
    libx11-xcb1 \
    libxcb1 \
    libxcomposite1 \
    libxdamage1 \
    libxext6 \
    libxfixes3 \
    libxkbcommon0 \
    libxrandr2 \
    xdg-utils \
    && rm -rf /var/lib/apt/lists/*

# 安装 Google Chrome Stable
RUN mkdir -p /etc/apt/keyrings && \
    wget -qO- https://dl.google.com/linux/linux_signing_key.pub | gpg --dearmor -o /etc/apt/keyrings/google.gpg && \
    echo "deb [arch=amd64 signed-by=/etc/apt/keyrings/google.gpg] http://dl.google.com/linux/chrome/deb/ stable main" > /etc/apt/sources.list.d/google-chrome.list && \
    apt-get update && \
    apt-get install -y --no-install-recommends google-chrome-stable && \
    rm -rf /var/lib/apt/lists/*

# 创建运行用户
RUN groupadd --system --gid 1001 nodejs && \
    useradd --system --uid 1001 --gid nodejs --create-home cursor

# 安装主项目生产依赖
COPY package.json package-lock.json ./
RUN npm ci --omit=dev --ignore-scripts && \
    npm cache clean --force

# 拷贝主项目构建产物
COPY --from=builder --chown=cursor:nodejs /app/dist ./dist
COPY --chown=cursor:nodejs public ./public

# 安装 stealth-proxy 依赖
COPY stealth-proxy/package.json ./stealth-proxy/
RUN cd stealth-proxy && npm install --omit=dev && npm cache clean --force

# 安装 Playwright Chromium 作为兜底（正常应优先走系统 Chrome）
RUN cd stealth-proxy && npx playwright install chromium

# 拷贝 stealth-proxy 代码
COPY --chown=cursor:nodejs stealth-proxy/index.js ./stealth-proxy/

# 日志目录
RUN mkdir -p /app/logs /app/.playwright-browsers && \
    chown -R cursor:nodejs /app

# 启动脚本
COPY --chown=cursor:nodejs start.sh ./
RUN chmod +x start.sh

# 切换非 root 用户
USER cursor

EXPOSE 3010

CMD ["./start.sh"]
